# =================================================================
# Cultimed monorepo .gitignore
# =================================================================

# ---- Node / Next.js ---------------------------------------------
**/node_modules/
**/.next/
**/dist/
**/build/
**/out/

# ---- Env y secretos --------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# ---- Datos sensibles -------------------------------------------
# Base de datos SQLite (datos reales de pacientes)
**/data/*.db
**/data/*.db-journal
**/data/*.db-shm
**/data/*.db-wal

# CSVs de exportación con datos personales (Shopify dumps de pacientes)
customers_export*.csv
products_export*.csv
**/scripts/source-data/customers.csv
**/scripts/source-data/products.csv

# Backups de BD (locales, fuera de git)
_backups/

# Uploads de pacientes (recetas, comprobantes)
**/uploads/
!**/uploads/.gitkeep
**/public/uploads/

# ---- Logs ------------------------------------------------------
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Cache / Build artifacts -----------------------------------
**/.turbo/
**/.cache/
**/.parcel-cache/
**/coverage/

# ---- IDE / OS --------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ---- Archivos legacy del directorio padre ---------------------
# (todo esto NO va al repo)
shopify-theme/
stitch/
stitch.zip
webapp/
*.zip
hf_*.png
theme_export__*.zip
cultimed-webapp-*.zip

# ---- TypeScript ------------------------------------------------
**/*.tsbuildinfo
**/next-env.d.ts.bak

# ---- Locks (mantenemos package-lock.json explícitamente) ------
# (no excluimos los lock files - los necesitamos para Railway)
yarn.lock
pnpm-lock.yaml
