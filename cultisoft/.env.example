# Cultisoft (admin) · variables de entorno

# Path al SQLite (persistente en producción)
DB_PATH=./data/cultisoft.db
# En Railway: DB_PATH=/data/cultisoft.db (volumen persistente compartido con storefront)

# Secret HMAC para firmar cookies de sesión staff. 32+ bytes random.
# Generar: openssl rand -hex 32
SESSION_SECRET=

# URL pública del storefront (para mostrar uploads de pacientes en preview admin)
STORE_PUBLIC_BASE=http://localhost:3000
# En prod: https://app.dispensariocultimed.cl
