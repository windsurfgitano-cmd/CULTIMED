# Cultimed Store · variables de entorno
# Copiar a .env.local (dev) o setear en el panel de Railway / hosting (prod)

# Path al SQLite compartido (relativo en dev, absoluto en prod)
DB_PATH=../cultisoft/data/cultisoft.db
# En Railway: DB_PATH=/data/cultisoft.db (volumen persistente compartido)

# Secret HMAC para firmar cookies de sesión cliente. 32+ bytes random.
# Generar: openssl rand -hex 32
SESSION_SECRET=

# URL pública del storefront (para QR de embajadores, links absolutos, return de MP)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# En prod: https://app.dispensariocultimed.cl

# MercadoPago (producción) — si vacío, MP queda deshabilitado y el selector lo muestra como Próximamente
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
