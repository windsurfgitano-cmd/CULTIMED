# Cultimed Store · variables de entorno
# Copiar a .env.local (dev) o setear en el panel de Vercel (prod)

# ---- Supabase Postgres ----
# Pooler URL para Vercel (transaction mode, port 6543).
# La encuentras en Supabase → Project Settings → Database → Connection string → "Transaction"
DATABASE_URL=postgres://postgres.[ref]:[PWD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---- Supabase API + Storage ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SOLO server-side, NO expongas en el cliente
SUPABASE_SERVICE_ROLE_KEY=

# ---- Sesiones ----
# Generar: openssl rand -hex 32
SESSION_SECRET=

# ---- URLs públicas ----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# En prod: https://app.dispensariocultimed.cl

# ---- MercadoPago ----
# Si vacío, MP queda deshabilitado y el selector lo muestra como Próximamente
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# ---- Datos bancarios públicos (mostrados en checkout transferencia) ----
NEXT_PUBLIC_BANK_NAME=BancoEstado
NEXT_PUBLIC_BANK_ACCOUNT_TYPE=Cuenta Corriente
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=
NEXT_PUBLIC_BANK_RUT=
NEXT_PUBLIC_BANK_HOLDER=Cultimed SpA
NEXT_PUBLIC_BANK_EMAIL=pagos@dispensariocultimed.cl
